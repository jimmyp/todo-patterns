{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "todos": {
        "ClusterId": "api",
        "Match": { "Path": "/todos/{**catch-all}" }
      },
      "categories": {
        "ClusterId": "api",
        "Match": { "Path": "/categories/{**catch-all}" }
      },
      "me": {
        "ClusterId": "api",
        "Match": { "Path": "/api/me" }
      },
      "hub": {
        "ClusterId": "api",
        "Match": { "Path": "/hubs/{**catch-all}" }
      }
    },
    "Clusters": {
      "api": {
        "Destinations": {
          "primary": {
            "Address": "https+http://api"
          }
        }
      }
    }
  }
}
